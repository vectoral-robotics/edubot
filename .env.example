# Copy to .env and adjust. Consumed by docker compose and the Makefile.

# Fleet image channel: stable | dev | vX.Y.Z
EDUBOT_CHANNEL=stable
# GitHub org that owns the GHCR images.
GHCR_OWNER=vectoral-robotics

# GHCR pull credentials for PRIVATE images (used by scripts/ghcr-login.sh).
# Prefer a root-owned /etc/edubot/ghcr-token file over putting the token here.
# The token needs only the read:packages scope. .env is gitignored — never commit it.
#GHCR_USER=edubot-bot
#GHCR_TOKEN=

# ROS
ROS_DOMAIN_ID=0
USE_SIM=true
USE_RVIZ=false
ENABLE_TELEOP=true
ENABLE_LIDAR=false
ENABLE_CAMERA=auto
CAMERA_DRIVER=cam2image

# RViz web (software rendering by default; set to gpu on capable hosts)
RVIZ_RENDER_MODE=software

# code-server (dev container) login password
CODE_SERVER_PASSWORD=edubot

# Dashboard
DASHBOARD_PORT=8080
# Vibe-coding LLM (optional — leave OPENAI_API_KEY empty to disable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Firmware reflash (make flash-fleet). Leave empty to auto-detect the board port.
EDUBOT_ESP32_PORT=
