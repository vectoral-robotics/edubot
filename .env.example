# Copy to .env and adjust. Consumed by docker compose and the Makefile.

# Fleet image channel: stable | dev | vX.Y.Z
EDUBOT_CHANNEL=stable
# GitHub org that owns the GHCR images.
GHCR_OWNER=vectoral-robotics

# ROS
ROS_DOMAIN_ID=0
USE_SIM=true
USE_RVIZ=false
ENABLE_TELEOP=true
ENABLE_LIDAR=false
ENABLE_CAMERA=auto

# Dashboard
DASHBOARD_PORT=8080
