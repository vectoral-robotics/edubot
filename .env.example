# Copy to .env and adjust. Consumed by docker compose and the Makefile.

# Fleet image channel: stable | dev | vX.Y.Z
EDUBOT_CHANNEL=stable
# GitHub org that owns the GHCR images.
GHCR_OWNER=vectoral-robotics

# GHCR pull credentials for PRIVATE images (used by scripts/ghcr-login.sh).
# Prefer a root-owned /etc/edubot/ghcr-token file over putting the token here.
# The token needs only the read:packages scope. .env is gitignored — never commit it.
#GHCR_USER=edubot-bot
#GHCR_TOKEN=

# ROS
ROS_DOMAIN_ID=0
USE_SIM=true
USE_RVIZ=false
ENABLE_TELEOP=true
ENABLE_LIDAR=false
ENABLE_CAMERA=auto

# Dashboard
DASHBOARD_PORT=8080
