# EduBot developer-only repos — imported into ./dev by `make src` (kept out of
# ./src so they never enter the colcon workspace, the lockfile, or the fleet
# image).
#
# These are NOT part of the colcon core workspace and are NOT shipped to the
# fleet as source. They are here so a developer / dev robot gets everything with
# a single `make src`.
#
# edubot_firmware is PRIVATE (proprietary). It is not a ROS package — it is the
# ESP32-S3 Arduino firmware plus host tools. `make flash` uses its tools/flash.sh
# to (re)flash the board from the machine it is plugged into (e.g. the Pi).
repositories:
  edubot_firmware:
    type: git
    url: https://github.com/vectoral-robotics/edubot_firmware.git
    version: main
  # The dashboard app source — so a dev can build the dashboard image locally
  # (docker-compose.dev.yaml) instead of pulling it. Not a ROS package.
  edubot_dashboard:
    type: git
    url: https://github.com/vectoral-robotics/edubot_dashboard.git
    version: main
